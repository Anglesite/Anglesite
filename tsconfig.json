{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist/app",
    "allowJs": true // Allow JavaScript files to be processed by TypeScript
  },
  "include": ["app", "app/types.d.ts", "types"]
}
