{
  "name": "@dwk/anglesite",
  "description": "A local-first, open-source WYSIWYG static site generator.",
  "version": "0.1.0",
  "homepage": "https://anglesite.dwk.io",
  "license": "ISC",
  "author": {
    "name": "David W. Keith",
    "email": "git@dwk.io",
    "url": "https://dwk.io"
  },
  "scripts": {
    "build:app": "tsc && cp app/ui/*.html dist/app/ui/ 2>/dev/null || true && mkdir -p dist/app/ui/templates && cp app/ui/templates/*.html dist/app/ui/templates/ 2>/dev/null || true && mkdir -p dist/app/eleventy && rsync -av app/eleventy/ dist/app/eleventy/ 2>/dev/null || true",
    "build:icons": "npm run build:icons:prepare && npm run build:icons:generate",
    "build:icons:prepare": "mkdir -p icons && cp icons/src/icon.svg icons/ 2>/dev/null || true",
    "build:icons:generate": "magick icons/src/icon.svg -resize 1024x1024 icons/icon.png && magick icons/src/icon.svg -resize 512x512 icons/icon@2x.png && magick icons/src/icon.svg -resize 256x256 icons/256x256.png && magick icons/src/icon.svg -resize 128x128 icons/128x128.png && magick icons/src/icon.svg -resize 64x64 icons/64x64.png && magick icons/src/icon.svg -resize 48x48 icons/48x48.png && magick icons/src/icon.svg -resize 32x32 icons/32x32.png && magick icons/src/icon.svg -resize 24x24 icons/24x24.png && magick icons/src/icon.svg -resize 16x16 icons/16x16.png",
    "build": "npm run build:app && eleventy --config=app/eleventy/.eleventy.js",
    "dist": "npm run build && npm run build:icons && electron-builder",
    "dist:mac": "npm run build && npm run build:icons && electron-builder --mac",
    "dist:win": "npm run build && npm run build:icons && electron-builder --win",
    "dist:linux": "npm run build && npm run build:icons && electron-builder --linux",
    "pack": "npm run build && npm run build:icons && electron-builder --dir",
    "format": "prettier --write .",
    "lint": "eslint . && markdownlint '**/*.md' --ignore node_modules --ignore dist",
    "prelint": "npm run format",
    "pretest": "tsc",
    "serve": "eleventy --config=app/eleventy/.eleventy.js --serve",
    "start": "electron .",
    "test:coverage": "jest --coverage --config jest.coverage.config.ts",
    "test": "jest"
  },
  "keywords": [
    "static site generator",
    "ssg",
    "wysiwyg",
    "electron",
    "11ty",
    "local-first"
  ],
  "main": "dist/app/main.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anglesite/anglesite.git"
  },
  "bugs": {
    "url": "https://github.com/anglesite/anglesite/issues"
  },
  "build": {
    "appId": "io.dwk.anglesite",
    "productName": "Anglesite",
    "asar": false,
    "directories": {
      "output": "dist/build",
      "buildResources": "icons"
    },
    "files": [
      "dist/app/**/*",
      "app/eleventy/**/*",
      "app/ui/**/*.html",
      "node_modules/**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!node_modules/*.d.ts",
      "!node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.editorconfig",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}"
    ],
    "mac": {
      "icon": "icons/icon.png",
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "icons/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ]
    },
    "linux": {
      "icon": "icons/",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "extraResources": [
      {
        "from": "app/eleventy",
        "to": "app/eleventy"
      }
    ]
  },
  "devDependencies": {
    "@11ty/eleventy-plugin-webc": "^0.11.2",
    "@electron/typescript-definitions": "^9.1.3",
    "@types/hostile": "^1.3.5",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^21.1.7",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^53.0.1",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.3.0",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "jsdom": "^26.1.0",
    "markdownlint-cli": "^0.45.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-dev-server": "^2.0.8",
    "@types/archiver": "^6.0.3",
    "archiver": "^7.0.1",
    "bagit-fs": "^1.1.1",
    "chokidar": "^3.6.0",
    "hostile": "^1.4.0",
    "live-server": "^1.2.2",
    "mkcert": "^3.2.0",
    "native-is-elevated": "^0.7.0",
    "sudo-prompt": "^9.2.1"
  }
}
