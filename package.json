{
  "name": "@dwk/anglesite",
  "version": "0.1.0",
  "description": "A local-first, open-source WYSIWYG static site generator.",
  "main": "dist/app/main.js",
  "scripts": {
    "start": "electron .",
    "build": "npm run build:app && eleventy --config=app/eleventy/.eleventy.js",
    "build:app": "tsc && cp app/ui/*.html dist/app/ui/ 2>/dev/null || true && mkdir -p dist/app/ui/templates && cp app/ui/templates/*.html dist/app/ui/templates/ 2>/dev/null || true",
    "serve": "eleventy --config=app/eleventy/.eleventy.js --serve",
    "prelint": "npm run format",
    "lint": "eslint . && markdownlint '**/*.md' --ignore node_modules --ignore dist",
    "format": "prettier --write .",
    "pretest": "tsc",
    "test": "jest",
    "test:coverage": "jest --coverage --config jest.coverage.config.ts",
    "test:dark-mode": "jest --coverage --collectCoverageFrom='app/ui/theme-manager.ts' test/ui/dark-mode-*.test.ts"
  },
  "keywords": [
    "static site generator",
    "ssg",
    "wysiwyg",
    "electron",
    "11ty",
    "local-first"
  ],
  "author": {
    "name": "David W. Keith",
    "email": "git@dwk.io",
    "url": "https://dwk.io"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anglesite/anglesite.git"
  },
  "bugs": {
    "url": "https://github.com/anglesite/anglesite/issues"
  },
  "homepage": "https://anglesite.dwk.io",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-plugin-webc": "^0.11.2",
    "@types/hostile": "^1.3.5",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^21.1.7",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "electron": "^37.2.6",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^53.0.1",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.3.0",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "jsdom": "^26.1.0",
    "live-server": "^1.2.2",
    "markdownlint-cli": "^0.45.0",
    "mkcert": "^3.2.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  },
  "dependencies": {
    "@types/archiver": "^6.0.3",
    "archiver": "^7.0.1",
    "bagit-fs": "^1.1.1",
    "hostile": "^1.4.0",
    "native-is-elevated": "^0.7.0",
    "sudo-prompt": "^9.2.1"
  }
}
