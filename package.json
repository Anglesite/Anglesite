{
  "name": "@dwk/anglesite",
  "description": "A local-first, open-source WYSIWYG static site generator.",
  "version": "0.1.0",
  "homepage": "https://anglesite.dwk.io",
  "license": "ISC",
  "author": {
    "name": "David W. Keith",
    "email": "git@dwk.io",
    "url": "https://dwk.io"
  },
  "scripts": {
    "build:app": "node bin/build-app.js",
    "build:icons": "node bin/build-icons.js",
    "build": "npm run build:app",
    "dist": "node bin/dist-build.js",
    "clear-cache": "node bin/clear-cache.js",
    "dist:mac": "node bin/dist-build.js mac",
    "dist:win": "node bin/dist-build.js win",
    "dist:linux": "node bin/dist-build.js linux",
    "pack": "node bin/dist-build.js dir",
    "format": "prettier --write .",
    "lint": "eslint . && markdownlint '**/*.md' --ignore node_modules --ignore dist && htmlhint 'app/**/*.html'",
    "lint:html": "htmlhint 'app/**/*.html'",
    "prelint": "npm run format",
    "prestart": "npm run build",
    "pretest": "tsc",
    "start": "electron .",
    "test:coverage": "jest --coverage --config jest.coverage.config.ts",
    "test": "jest"
  },
  "keywords": [
    "static site generator",
    "ssg",
    "wysiwyg",
    "electron",
    "11ty",
    "local-first"
  ],
  "main": "dist/app/main.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anglesite/anglesite.git"
  },
  "bugs": {
    "url": "https://github.com/anglesite/anglesite/issues"
  },
  "build": {
    "appId": "io.dwk.anglesite",
    "productName": "Anglesite",
    "asar": true,
    "asarUnpack": [
      "app/eleventy/**/*",
      "dist/app/eleventy/**/*",
      "app/ui/**/*",
      "dist/app/ui/**/*"
    ],
    "directories": {
      "output": "dist/build",
      "buildResources": "icons"
    },
    "files": [
      "dist/app/**/*",
      "app/eleventy/**/*",
      "app/ui/**/*.html",
      "node_modules/**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!node_modules/*.d.ts",
      "!node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.editorconfig",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}"
    ],
    "mac": {
      "icon": "icons/icon.png",
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "icons/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ]
    },
    "linux": {
      "icon": "icons/",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "extraResources": [
      {
        "from": "app/eleventy",
        "to": "app/eleventy"
      },
      {
        "from": "app/ui/templates",
        "to": "app/ui/templates"
      }
    ]
  },
  "devDependencies": {
    "@11ty/eleventy-plugin-webc": "^0.11.2",
    "@electron/typescript-definitions": "^9.1.3",
    "@types/hostile": "^1.3.5",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^21.1.7",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^53.0.1",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.3.0",
    "htmlhint": "^1.6.3",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "jsdom": "^26.1.0",
    "markdownlint-cli": "^0.45.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-dev-server": "^2.0.8",
    "@json-editor/json-editor": "^2.15.2",
    "@types/archiver": "^6.0.3",
    "ace-builds": "^1.43.2",
    "archiver": "^7.0.1",
    "bagit-fs": "^1.1.1",
    "chokidar": "^3.6.0",
    "glob": "^11.0.3",
    "hostile": "^1.4.0",
    "js-yaml": "^4.1.0",
    "live-server": "^1.2.2",
    "lucide-static": "^0.539.0",
    "mkcert": "^3.2.0",
    "native-is-elevated": "^0.7.0",
    "sudo-prompt": "^9.2.1"
  }
}
