/**
 * @file Tests for Eleventy server management
 */
import {
  getCurrentLiveServerUrl,
  isLiveServerReady,
  setLiveServerUrl,
  getCurrentWebsiteName,
  setCurrentWebsiteName,
  generateTestDomain,
  getHostnameFromTestDomain,
  cleanupEleventyServer,
  startEleventyServer,
  stopEleventyServer,
  switchToWebsite,
  startDefaultEleventyServer,
} from '../../app/server/eleventy';
import { spawn } from 'child_process';
import { EventEmitter } from 'events';

// Mock child_process
jest.mock('child_process');

// Mock fs
jest.mock('fs', () => ({
  existsSync: jest.fn(() => true),
  mkdirSync: jest.fn(),
  statSync: jest.fn(() => ({ isDirectory: () => false })),
  readFile: jest.fn((_path, cb) => cb(null, 'test content')),
  rmSync: jest.fn(),
}));

// Mock @11ty/eleventy-dev-server
jest.mock('@11ty/eleventy-dev-server', () => {
  const mockDevServer = {
    serve: jest.fn(),
    ready: jest.fn().mockResolvedValue(undefined),
    close: jest.fn().mockResolvedValue(undefined),
    watchFiles: jest.fn(),
    reloadFiles: jest.fn(),
    watcher: {
      on: jest.fn(),
      removeAllListeners: jest.fn(),
    },
  };
  return jest.fn().mockImplementation(() => mockDevServer);
});

// Mock Eleventy
jest.mock('@11ty/eleventy', () => {
  const mockEleventy = {
    write: jest.fn().mockResolvedValue(undefined),
  };
  return jest.fn().mockImplementation(() => mockEleventy);
});

const mockSpawn = spawn as jest.MockedFunction<typeof spawn>;

// Get references to mocked fs functions
const fs = require('fs');
const mockFs = {
  existsSync: fs.existsSync as jest.MockedFunction<typeof fs.existsSync>,
  mkdirSync: fs.mkdirSync as jest.MockedFunction<typeof fs.mkdirSync>,
  statSync: fs.statSync as jest.MockedFunction<typeof fs.statSync>,
  readFile: fs.readFile as jest.MockedFunction<typeof fs.readFile>,
  rmSync: fs.rmSync as jest.MockedFunction<typeof fs.rmSync>,
};

// Get references to mocked constructors
const MockEleventyDevServer = require('@11ty/eleventy-dev-server');
const MockEleventyConstructor = require('@11ty/eleventy');

// Get mock instances for testing
let mockDevServer: any;
let mockEleventy: any;

describe('Eleventy Server Management', () => {
  let mockProcess: any;
  let consoleLogSpy: jest.SpyInstance;
  let consoleErrorSpy: jest.SpyInstance;
  let consoleWarnSpy: jest.SpyInstance;

  beforeEach(() => {
    jest.clearAllMocks();
    jest.useFakeTimers();

    // Spy on console methods
    consoleLogSpy = jest.spyOn(console, 'log').mockImplementation();
    consoleErrorSpy = jest.spyOn(console, 'error').mockImplementation();
    consoleWarnSpy = jest.spyOn(console, 'warn').mockImplementation();

    // Create mock process
    mockProcess = new EventEmitter();
    mockProcess.stdout = new EventEmitter();
    mockProcess.stderr = new EventEmitter();
    mockProcess.kill = jest.fn();

    mockSpawn.mockReturnValue(mockProcess as any);

    // Get mock instances (they are created when the constructors are called)
    // We need to reset them before each test
    mockDevServer = {
      serve: jest.fn(),
      ready: jest.fn().mockResolvedValue(undefined),
      close: jest.fn().mockResolvedValue(undefined),
      watchFiles: jest.fn(),
      reloadFiles: jest.fn(),
      watcher: {
        on: jest.fn(),
        removeAllListeners: jest.fn(),
      },
    };
    mockEleventy = {
      write: jest.fn().mockResolvedValue(undefined),
    };

    // Update mocks to return our instances
    MockEleventyDevServer.mockImplementation(() => mockDevServer);
    MockEleventyConstructor.mockImplementation(() => mockEleventy);

    // Reset mocks
    mockFs.existsSync.mockReturnValue(true);
    mockFs.statSync.mockReturnValue({ isDirectory: () => false });

    // Reset server state
    setLiveServerUrl('https://localhost:8080');
    setCurrentWebsiteName('anglesite');
  });

  afterEach(() => {
    jest.useRealTimers();
    consoleLogSpy.mockRestore();
    consoleErrorSpy.mockRestore();
    consoleWarnSpy.mockRestore();
  });

  describe('URL and state management', () => {
    it('should get and set live server URL', () => {
      const testUrl = 'https://test.example.com:3000';
      setLiveServerUrl(testUrl);
      expect(getCurrentLiveServerUrl()).toBe(testUrl);
    });

    it('should track server ready state', () => {
      // Setting URL should mark server as ready
      setLiveServerUrl('https://localhost:8080');
      expect(isLiveServerReady()).toBe(true);
    });

    it('should get and set current website name', () => {
      const testName = 'my-test-website';
      setCurrentWebsiteName(testName);
      expect(getCurrentWebsiteName()).toBe(testName);
    });
  });

  describe('Test domain generation', () => {
    it('should generate test domain URLs', () => {
      const websiteName = 'my-blog';
      const testDomain = generateTestDomain(websiteName);
      expect(testDomain).toBe('https://my-blog.test:8080');
    });

    it('should generate test domains for different website names', () => {
      expect(generateTestDomain('portfolio')).toBe('https://portfolio.test:8080');
      expect(generateTestDomain('company-site')).toBe('https://company-site.test:8080');
      expect(generateTestDomain('docs')).toBe('https://docs.test:8080');
    });
  });

  describe('Hostname extraction', () => {
    it('should extract hostname from test domain URL', () => {
      const testDomain = 'https://my-blog.test:8080';
      const hostname = getHostnameFromTestDomain(testDomain);
      expect(hostname).toBe('my-blog.test');
    });

    it('should extract hostname from different URLs', () => {
      expect(getHostnameFromTestDomain('https://portfolio.test:8080')).toBe('portfolio.test');
      expect(getHostnameFromTestDomain('http://localhost:3000')).toBe('localhost');
      expect(getHostnameFromTestDomain('https://example.com')).toBe('example.com');
    });

    it('should handle invalid URLs gracefully', () => {
      const invalidUrl = 'not-a-valid-url';
      const hostname = getHostnameFromTestDomain(invalidUrl);
      expect(hostname).toBe('localhost');
    });

    it('should handle malformed URLs', () => {
      expect(getHostnameFromTestDomain('')).toBe('localhost');
      expect(getHostnameFromTestDomain('://')).toBe('localhost');
      expect(getHostnameFromTestDomain('http://')).toBe('localhost');
    });
  });

  describe('Server cleanup', () => {
    it('should provide cleanup function', async () => {
      expect(typeof cleanupEleventyServer).toBe('function');

      // Should not throw when called
      await expect(cleanupEleventyServer()).resolves.not.toThrow();
    });
  });

  describe('Integration scenarios', () => {
    it('should handle website switching workflow', () => {
      const websiteName = 'new-project';
      const testDomain = generateTestDomain(websiteName);
      const hostname = getHostnameFromTestDomain(testDomain);

      setCurrentWebsiteName(websiteName);
      setLiveServerUrl(testDomain);

      expect(getCurrentWebsiteName()).toBe(websiteName);
      expect(getCurrentLiveServerUrl()).toBe(testDomain);
      expect(hostname).toBe(`${websiteName}.test`);
      expect(isLiveServerReady()).toBe(true);
    });

    it('should handle default Anglesite setup', () => {
      setCurrentWebsiteName('anglesite');
      setLiveServerUrl('https://anglesite.test:8080');

      expect(getCurrentWebsiteName()).toBe('anglesite');
      expect(getCurrentLiveServerUrl()).toBe('https://anglesite.test:8080');
      expect(isLiveServerReady()).toBe(true);
    });
  });

  describe('Server lifecycle', () => {
    describe('startEleventyServer', () => {
      it('should start Eleventy server with default parameters', async () => {
        await startEleventyServer();

        expect(MockEleventyConstructor).toHaveBeenCalledWith('docs', expect.stringContaining('docs'), {
          quietMode: true,
          configPath: expect.stringContaining('.eleventy.js'),
        });
        expect(mockEleventy.write).toHaveBeenCalled();
        expect(MockEleventyDevServer).toHaveBeenCalledWith(
          'anglesite',
          expect.stringContaining('docs'),
          expect.objectContaining({
            port: 8081,
            liveReload: true,
            domDiff: true,
            showVersion: false,
          })
        );
        expect(mockDevServer.serve).toHaveBeenCalledWith(8081);
        expect(mockDevServer.ready).toHaveBeenCalled();
        expect(consoleLogSpy).toHaveBeenCalledWith('Starting Eleventy server for: docs');
      });

      it('should start Eleventy server with custom parameters', async () => {
        await startEleventyServer('custom-dir', 9000);

        expect(MockEleventyConstructor).toHaveBeenCalledWith('custom-dir', expect.stringContaining('custom-dir'), {
          quietMode: true,
          configPath: expect.stringContaining('.eleventy.js'),
        });
        expect(MockEleventyDevServer).toHaveBeenCalledWith(
          'anglesite',
          expect.stringContaining('custom-dir'),
          expect.objectContaining({
            port: 9000,
          })
        );
        expect(mockDevServer.serve).toHaveBeenCalledWith(9000);
        expect(consoleLogSpy).toHaveBeenCalledWith('Starting Eleventy server for: custom-dir');
      });

      it('should stop existing server before starting new one', async () => {
        // Start first server
        await startEleventyServer();

        // Start second server
        await startEleventyServer('different-dir');

        expect(mockDevServer.close).toHaveBeenCalled();
        expect(MockEleventyConstructor).toHaveBeenCalledTimes(2);
        expect(MockEleventyDevServer).toHaveBeenCalledTimes(2);
      });

      it('should call onReady when server starts', async () => {
        const onReady = jest.fn();
        await startEleventyServer('docs', 8081, onReady);

        expect(onReady).toHaveBeenCalledWith('http://localhost:8081');
        expect(isLiveServerReady()).toBe(true);
      });

      it('should handle build errors', async () => {
        const onError = jest.fn();
        mockEleventy.write.mockRejectedValue(new Error('Build failed'));

        await startEleventyServer('docs', 8081, undefined, onError);

        expect(consoleErrorSpy).toHaveBeenCalledWith('Failed to start Eleventy dev server:', expect.any(Error));
        expect(onError).toHaveBeenCalledWith('Build failed');
      });

      it('should handle file watcher events', async () => {
        await startEleventyServer();

        // Get the file watcher callback
        const changeCallback = mockDevServer.watcher.on.mock.calls.find((call: any) => call[0] === 'change')[1];

        // Simulate file change
        await changeCallback('test-file.md');

        expect(mockEleventy.write).toHaveBeenCalledTimes(2); // Initial build + rebuild
        expect(mockDevServer.reloadFiles).toHaveBeenCalledWith(['test-file.md']);
        expect(consoleLogSpy).toHaveBeenCalledWith('File changed: test-file.md, rebuilding...');
      });

      it('should handle file watcher rebuild errors', async () => {
        const onError = jest.fn();
        await startEleventyServer('docs', 8081, undefined, onError);

        // Mock rebuild failure
        mockEleventy.write.mockRejectedValueOnce(new Error('Rebuild failed'));

        // Get the file watcher callback
        const changeCallback = mockDevServer.watcher.on.mock.calls.find((call: any) => call[0] === 'change')[1];

        // Simulate file change
        await changeCallback('test-file.md');

        expect(consoleErrorSpy).toHaveBeenCalledWith('Rebuild failed:', expect.any(Error));
        expect(onError).toHaveBeenCalledWith('Rebuild failed');
      });

      it('should create output directory if it does not exist', async () => {
        mockFs.existsSync.mockReturnValue(false);

        await startEleventyServer();

        expect(mockFs.mkdirSync).toHaveBeenCalledWith(expect.stringContaining('docs'), { recursive: true });
      });

      it('should set up file watching with dev server', async () => {
        await startEleventyServer();

        expect(mockDevServer.watchFiles).toHaveBeenCalledWith(['docs/**/*']);
        expect(mockDevServer.watcher.removeAllListeners).toHaveBeenCalledWith('change');
        expect(mockDevServer.watcher.removeAllListeners).toHaveBeenCalledWith('add');
        expect(mockDevServer.watcher.removeAllListeners).toHaveBeenCalledWith('unlink');
      });

      it('should configure dev server with correct options', async () => {
        await startEleventyServer('my-site', 3000);

        expect(MockEleventyDevServer).toHaveBeenCalledWith(
          'anglesite',
          expect.stringContaining('my-site'),
          expect.objectContaining({
            port: 3000,
            liveReload: true,
            domDiff: true,
            showVersion: false,
            watch: ['my-site/**/*'],
            logger: expect.objectContaining({
              log: console.log,
              info: console.log,
              error: console.error,
            }),
          })
        );
      });
    });

    describe('stopEleventyServer', () => {
      it('should stop running server', async () => {
        // Start server first
        await startEleventyServer();

        await stopEleventyServer();

        expect(consoleLogSpy).toHaveBeenCalledWith('Stopping Eleventy server');
        expect(mockDevServer.close).toHaveBeenCalled();
        expect(isLiveServerReady()).toBe(false);
      });

      it('should clean up output directory', async () => {
        await startEleventyServer();

        await stopEleventyServer();

        expect(mockFs.rmSync).toHaveBeenCalledWith(expect.stringContaining('docs'), { recursive: true, force: true });
      });

      it('should handle stopping when no server is running', async () => {
        await stopEleventyServer();

        // Should not throw
        expect(consoleLogSpy).toHaveBeenCalledWith('Stopping Eleventy server');
      });

      it('should handle dev server close errors gracefully', async () => {
        await startEleventyServer();
        mockDevServer.close.mockRejectedValue(new Error('Close failed'));

        await stopEleventyServer();

        expect(consoleWarnSpy).toHaveBeenCalledWith('Error stopping dev server:', expect.any(Error));
      });
    });

    describe('switchToWebsite', () => {
      it('should switch to new website successfully', async () => {
        const websitePath = '/path/to/website';

        const port = await switchToWebsite(websitePath);

        expect(consoleLogSpy).toHaveBeenCalledWith('Switching to website at:', websitePath);
        expect(MockEleventyConstructor).toHaveBeenCalledWith(
          websitePath,
          expect.stringContaining('website'),
          expect.any(Object)
        );
        expect(port).toBe(8081);
      });

      it('should handle server start error', async () => {
        const websitePath = '/path/to/website';
        mockEleventy.write.mockRejectedValue(new Error('Failed to start'));

        await expect(switchToWebsite(websitePath)).rejects.toThrow('Failed to start');
        expect(consoleErrorSpy).toHaveBeenCalledWith('Failed to start server for new website:', 'Failed to start');
      });

      it('should use custom port correctly', async () => {
        const websitePath = '/path/to/website';

        const port = await switchToWebsite(websitePath);

        expect(mockDevServer.serve).toHaveBeenCalledWith(8081);
        expect(port).toBe(8081);
      });
    });

    describe('startDefaultEleventyServer', () => {
      it('should start default server with HTTPS mode', async () => {
        const mockMainWindow = {} as any;
        const mockAddLocalDnsResolution = jest.fn().mockResolvedValue(undefined);
        const mockCreateHttpsProxy = jest.fn().mockResolvedValue(true);
        const mockAutoLoadPreview = jest.fn();

        await startDefaultEleventyServer(
          'https',
          mockMainWindow,
          mockAddLocalDnsResolution,
          mockCreateHttpsProxy,
          mockAutoLoadPreview
        );

        expect(mockAddLocalDnsResolution).toHaveBeenCalledWith('anglesite.test');
        expect(mockCreateHttpsProxy).toHaveBeenCalledWith(8080, 8081, 'anglesite.test');
        expect(getCurrentLiveServerUrl()).toBe('https://anglesite.test:8080');
        expect(getCurrentWebsiteName()).toBe('anglesite');
        expect(mockAutoLoadPreview).toHaveBeenCalledWith(mockMainWindow);
      });

      it('should handle HTTPS proxy failure', async () => {
        const mockMainWindow = {} as any;
        const mockAddLocalDnsResolution = jest.fn().mockResolvedValue(undefined);
        const mockCreateHttpsProxy = jest.fn().mockResolvedValue(false);
        const mockAutoLoadPreview = jest.fn();

        await startDefaultEleventyServer(
          'https',
          mockMainWindow,
          mockAddLocalDnsResolution,
          mockCreateHttpsProxy,
          mockAutoLoadPreview
        );

        expect(mockCreateHttpsProxy).toHaveBeenCalled();
        expect(getCurrentLiveServerUrl()).toBe('http://localhost:8081');
        expect(consoleLogSpy).toHaveBeenCalledWith('⚠️  HTTPS proxy failed, falling back to HTTP mode');
        expect(mockAutoLoadPreview).toHaveBeenCalledWith(mockMainWindow);
      });

      it('should start default server with HTTP mode', async () => {
        const mockMainWindow = {} as any;
        const mockAddLocalDnsResolution = jest.fn().mockResolvedValue(undefined);
        const mockCreateHttpsProxy = jest.fn();
        const mockAutoLoadPreview = jest.fn();

        await startDefaultEleventyServer(
          'http',
          mockMainWindow,
          mockAddLocalDnsResolution,
          mockCreateHttpsProxy,
          mockAutoLoadPreview
        );

        expect(mockAddLocalDnsResolution).toHaveBeenCalledWith('anglesite.test');
        expect(mockCreateHttpsProxy).not.toHaveBeenCalled();
        expect(getCurrentLiveServerUrl()).toBe('http://localhost:8081');
        expect(consoleLogSpy).toHaveBeenCalledWith('✅ Eleventy server is ready (HTTP-only mode by user preference)');
        expect(mockAutoLoadPreview).toHaveBeenCalledWith(mockMainWindow);
      });

      it('should handle null main window gracefully', async () => {
        const mockAddLocalDnsResolution = jest.fn().mockResolvedValue(undefined);
        const mockCreateHttpsProxy = jest.fn().mockResolvedValue(true);
        const mockAutoLoadPreview = jest.fn();

        await startDefaultEleventyServer(
          'https',
          null,
          mockAddLocalDnsResolution,
          mockCreateHttpsProxy,
          mockAutoLoadPreview
        );

        expect(mockAutoLoadPreview).not.toHaveBeenCalled();
      });

      it('should handle server error', async () => {
        const mockMainWindow = {} as any;
        const mockAddLocalDnsResolution = jest.fn();
        const mockCreateHttpsProxy = jest.fn();
        const mockAutoLoadPreview = jest.fn();
        const onError = jest.fn();

        mockEleventy.write.mockRejectedValue(new Error('Server failed'));

        await startDefaultEleventyServer(
          'https',
          mockMainWindow,
          mockAddLocalDnsResolution,
          mockCreateHttpsProxy,
          mockAutoLoadPreview
        );

        expect(consoleErrorSpy).toHaveBeenCalledWith('Failed to start Eleventy dev server:', expect.any(Error));
      });
    });
  });
});
